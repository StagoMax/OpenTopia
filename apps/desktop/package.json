{
  "name": "@opentopia/desktop",
  "version": "0.1.0",
  "private": true,
  "author": "OpenTopia Contributors",
  "description": "OpenTopia desktop workbench.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "start": "electron .",
    "build": "tsc --noEmit && vite build",
    "smoke:browser-host": "electron electron/browser-host-smoke.cjs",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.cjs\""
  },
  "build": {
    "appId": "ai.opentopia.desktop",
    "productName": "OpenTopia",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "opentopia-server",
          "opentopia-server.exe"
        ]
      },
      {
        "from": "resources/codex-sandbox",
        "to": "codex-sandbox",
        "filter": [
          "codex.exe",
          "codex-command-runner.exe",
          "codex-windows-sandbox-setup.exe",
          "manifest.json",
          "LICENSE"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "opentopia",
      "repo": "opentopia",
      "releaseType": "draft"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "electron-updater": "^6.6.0",
    "lucide-react": "^0.575.0",
    "monaco-editor": "^0.52.2",
    "pdfjs-dist": "4.10.38",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.12",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.3"
  }
}
