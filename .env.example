OPENTOPIA_DB=.opentopia/opentopia.db
OPENTOPIA_SERVER_URL=http://127.0.0.1:8787
# Required for direct server launches. Electron generates a fresh random token.
OPENTOPIA_API_TOKEN=replace-with-at-least-32-random-bytes
OPENTOPIA_PERMISSION=auto
OPENTOPIA_CONTEXT_WINDOW_TOKENS=128000
OPENTOPIA_CONTEXT_COMPACT_THRESHOLD_PERCENT=80
OPENTOPIA_SANDBOX_MODE=best_effort
OPENTOPIA_SANDBOX_NETWORK=deny
# OPENTOPIA_CODEX_SANDBOX_BIN=C:\path\to\codex.exe
OPENTOPIA_MODEL=gpt-4.1-mini
OPENTOPIA_OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# Optional: reuse an existing env file. If this is unset, OpenTopia also checks
# the sibling project env at J:\Project\信贷审核助手\.env when it exists.
# OPENTOPIA_ENV_FILE=J:\Project\信贷审核助手\.env

# Supported aliases from 信贷审核助手:
# CREDIT_REVIEW_LLM_API_KEY -> OPENTOPIA_API_KEY
# CREDIT_REVIEW_LLM_BASE_URL -> OPENTOPIA_OPENAI_BASE_URL
# CREDIT_REVIEW_LLM_MODEL -> OPENTOPIA_MODEL
